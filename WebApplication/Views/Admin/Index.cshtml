@model Profiles.Business.ProfileCollection

@{
    ViewBag.Title = "Admin: Profiles";
}

<div>
    @if (TempData["message"] != null)
    {
        <div class="alert alert-success">@TempData["message"]</div>
    }
</div>

<div class="panel panel-default">
    <div class="panel-heading">
        <h3>Edit Profiles</h3>
    </div>
    <div class="panel-body">
        <table class="table table-striped table-condensed table-bordered">
            <tr>
                <th class="text-right">ID</th>
                <th>Name</th>
                <th>Role</th>
                <th>Company</th>
                <th>Title</th>
                <th>&nbsp;</th>
                <th>&nbsp;</th>
            </tr>

            @foreach (var item in Model.ProfileList)
            {
                <tr id="adminTable">
                    <td class="text-right">@item.ID</td>
                    <td>@(item.FirstName + " " + item.LastName)</td>
                    <td>@item.SPIERole</td>
                    <td>@item.Company</td>
                    <td>@item.JobTitle</td>
                    <td class="text-center"><img src="~/Images/ProfilePictures/@item.PictureFileName" alt="picture" /></td>
                    <td class="text-center"><strong>@Html.ActionLink("Edit", "Edit", new { item.ID })</strong></td>
                </tr>
            }
        </table>
    </div>
</div>


