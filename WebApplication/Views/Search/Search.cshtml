@{
    ViewBag.Title = "Search View";
}

<h2>Results</h2>

<div style="display:inline-block;vertical-align:top;background-color:#ededee;margin-top:10px;padding: 5px 10px 10px 10px;width: 335px;">

    <div style="background-color: #000000; height: 8px; width: 316px;">
    </div>

    @foreach (var profile in Model)
    {
        <div style="margin: 10px 0px;">

            <img id="imagePerson" title="@profile.FirstName" alt="@profile.FirstName" src="/images/profilepictures/@profile.PictureFileName" height="72" width="56" style="border-width:0px;display:inline-block;" />

            <div style="display:inline-block;vertical-align:top;height:72px;width:220px;margin-left: 20px;">
                <div>
                    <a target="_blank" href="/profiles/view/@profile.ID">@profile.FirstName @profile.LastName </a>
                </div>
                <div>
                    @profile.Company <br />
                    @profile.SPIERole
                </div>

            </div>
        </div>
        <div style="height: 1px; width: 316px; background-color: #bfc0c1;"></div>
    }
</div>

