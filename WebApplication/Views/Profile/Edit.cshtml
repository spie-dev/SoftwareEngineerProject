@model Profiles.Business.Profile

@{
    /**/

    ViewBag.Title = "Edit";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Edit</h2>

<style type="text/css">
    tr {
        height: 50px;
    }

    table {
        margin: 50px 10px;
    }
</style>


@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-horizontal">
        <hr />
        <div class="form-group">
            <table>
                <tr>
                    <td>@Html.LabelFor(a => a.FirstName)</td>
                    <td>@Html.EditorFor(a => a.FirstName) @Html.ValidationMessageFor(a => a.FirstName, "", new { @class = "text-danger" })</td>
                </tr>
                <tr>
                    <td>@Html.LabelFor(a => a.LastName)</td>
                    <td>@Html.EditorFor(a => a.LastName) @Html.ValidationMessageFor(a => a.LastName, "", new { @class = "text-danger" })</td>
                </tr>
                <tr>
                    <td>@Html.LabelFor(a => a.Company)</td>
                    <td>@Html.EditorFor(a => a.Company) @Html.ValidationMessageFor(a => a.Company, "", new { @class = "text-danger" })</td>
                </tr>
                <tr>
                    <td>@Html.LabelFor(a => a.SPIERole)</td>
                    <td>@Html.EditorFor(a => a.SPIERole) @Html.ValidationMessageFor(a => a.SPIERole, "", new { @class = "text-danger" })</td>
                </tr>
                <tr>
                    <td>@Html.LabelFor(a => a.JobTitle)</td>
                    <td>@Html.EditorFor(a => a.JobTitle) @Html.ValidationMessageFor(a => a.JobTitle, "", new { @class = "text-danger" })</td>
                </tr>
            </table>
            <div class="col-md-offset-2 col-md-10">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </div>
    </div>
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
